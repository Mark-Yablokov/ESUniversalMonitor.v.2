procedure TForm1.Timer2Timer(Sender: TObject);
begin

//В таймере №2 периодически запрашиваем данные из МК
  if ReadData=false then //если данные отосланы и успешно приняты, то
  begin
    //Посылаем команду измерить и передать
    KolByte:=1;
    FT_Out_Buffer[0]:=5;
    WriteComm;
    ReadData:=true; //говорим потоку что данные ушли
  end;

  //тут же проверяем есть ли вообще USB
  PortStatus:=GetFTDeviceCount;
  if FT_Device_Count=0 then  //Если приборов=0, то USB соединения нет
  begin
    Form1.Timer2.Enabled:=false;
    Form1.Timer1.Enabled:=true;
  end;
end;

