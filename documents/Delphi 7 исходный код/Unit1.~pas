// процедура записи в USB-порт
 procedure WriteComm();
 var k:integer;
 begin
   PortStatus:=Write_USB_Device_Buffer(KolByte);
 end;

 // процедура обработки потока с USB-порта
 procedure ReadComm;
  var
   Resive:array [0..255] of byte;
   Pressure1:double;
   TransMask,Errs,b:DWord;
   result:integer;
   delay:integer;
  begin
    while true do
    begin
    result:=WaitForSingleObject(hEvent,1000);
    PortStatus:=FT_SetEventNotification(FT_Handle,FT_EVENT_RXCHAR ,hEvent);

    //есть ли в буфере даныне?
    if ReadData=true then //если данные отправлены Timer2, то пробуем получить ответ
    begin
      sleep(200);//ждём пока данные дойдут по USB
      FT_GetStatus(FT_Handle, @FT_Q_Bytes, @FT_TxQ_Bytes, @FT_Event_Status);
      If FT_Q_Bytes>data_num-1 then
      begin
        Number_of_fault:=0; //обнуляем счётчик неудачных считываний с МК
//        PortStatus:=Read_USB_Device_Buffer(data_num);
        PortStatus:=Read_USB_Device_Buffer(FT_Q_Bytes);
        if FT_In_Buffer[4]=13 then
        begin
          // обрабатываю данные от микроконтроллера

          // монитор выходного напряжения
          HV_DIV:=(FT_In_Buffer[2]*256+FT_In_Buffer[3])*Voltmax/Codemax_ADC/16; {16 - кол-во усреднений в в АЦП внутри МК}
          If Polarity='N' then HV_DIV:=HV_DIV*(-1); //если прибор с отрицательной полярностью, то значение вых напряжения минусуем
          if (Voltmax>15000-1) and (Voltmax<30001) then
            begin
              HV_DIV:=round(HV_DIV/10)*10;
              str(HV_DIV:0:0,st);
            end;

          If abs(HV_DIV)<Voltmin*0.7 then HV_DIV:=0; //минимальное напряжение не показываем

          str(HV_DIV:0:volt_view,st);
          Form1.Edit7.Text:=st;

          // монитор выходного тока
          I_SUPPLY:=(FT_In_Buffer[0]*256+FT_In_Buffer[1])*Imax/Codemax_DAC;

          //Вычитаем ток по резистору обратной связи.
          //If Iunits='мА' then I_SUPPLY:=I_SUPPLY-abs(HV_DIV/1000/Ros);
          If Iunits='мкА' then I_SUPPLY:=I_SUPPLY-abs(HV_DIV/Ros);

          //минимальный ток не показываем
          If I_SUPPLY<Imin then I_SUPPLY:=0;

         If Iunits='мА' then I_SUPPLY:=I_SUPPLY/1000;

          //выводим на экран
          If CurrentStep=10 then I_SUPPLY:=round(I_SUPPLY/10)*10; // если токи большие, то округляем до десятков
          str(I_SUPPLY:0:current_view,st);
          Form1.Edit1.Text:=st;

          //пишем что нить в панели состояния
          If High_Voltage_On=1 then
          begin
            Form1.Panel1.Color:=clRed;
            If The_language='Русский' then Form1.Panel1.Caption:='Включен';
            If The_language='English' then Form1.Panel1.Caption:='ON';
          end
          else
          begin
            Form1.Panel1.Color:=clMoneyGreen;
            If The_language='Русский' then Form1.Panel1.Caption:='Отключен';
            If The_language='English' then Form1.Panel1.Caption:='OFF';

          end;
          ReadData:=false; //Ждём пока Timer2 пошлёт следующую порцию данных
         end
         else //последнее число 13
          begin
            ReadData:=false;
            Number_of_fault:=Number_of_fault+1;
            If Number_of_fault>Number_of_fault_MAX then begin
              Form1.Panel1.Color:=clMoneyGreen;
              If The_language='Русский' then Form1.Panel1.Caption:='Нет питания прибора';
              If The_language='English' then Form1.Panel1.Caption:='No power supply';
              //в индикаторы пишем нули
              Form1.Edit7.Text:='- - - -';
              Form1.Edit1.Text:='- - - -';
              High_Voltage_On:=0; // прога знает что ВВ отключен
              Form1.Timer1.Enabled:=true; //запускаем таймер1, что бы инициализировал
              Form1.Timer2.Enabled:=false;
            end;
          end;
          end //если не дождались данных то пишем что нет питания
            else begin//нет?
            ReadData:=false;
            Number_of_fault:=Number_of_fault+1;
              If Number_of_fault>Number_of_fault_MAX then begin
                Form1.Panel1.Color:=clMoneyGreen;
                If The_language='Русский' then Form1.Panel1.Caption:='Нет питания прибора';
                If The_language='English' then Form1.Panel1.Caption:='No power supply';
                //в индикаторы пишем нули
                Form1.Edit7.Text:='- - - -';
                Form1.Edit1.Text:='- - - -';
                High_Voltage_On:=0; // прога знает что ВВ отключен
                Form1.Timer1.Enabled:=true; //запускаем таймер1, что бы инициализировал
                Form1.Timer2.Enabled:=false;
              end;
            end;
     end; //if ReadData....
   end;//while
   end;

procedure TForm1.Button2Click(Sender: TObject);   //Процедура обновления выходного напряжения
begin
  Timer2.Enabled:=false;
  Panel1.Color:=clRed;

  If The_language='Русский' then Form1.Panel1.Caption:='Включен';
  If The_language='English' then Form1.Panel1.Caption:='ON';
  High_Voltage_On:=1;

//  Передаём значение напряжения

  KolByte:=1; //оправляем комманду микроконтроллеру
  value:=round(Form1.SpinEdit2.Value*(Codemax_DAC/Voltmax)); //преобразуем напряжение в коды

  //отправляем
  FT_Out_Buffer[0]:=1;
  WriteComm;
  sleep(50);
  FT_Out_Buffer[0]:=value-trunc(value/256)*256;
  WriteComm;
  sleep(50);
  FT_Out_Buffer[0]:=trunc(value/256);
  WriteComm;
  sleep(50);

  //  Передаём значение тока
  value:=round(Form1.SpinEdit1.Value*(Codemax_DAC/Imax)); //преобразуем ток в коды

  //отправляем
  FT_Out_Buffer[0]:=value-trunc(value/256)*256;
  WriteComm;
  sleep(50);
  FT_Out_Buffer[0]:=trunc(value/256);
  WriteComm;
  sleep(50);

  FT_Out_Buffer[0]:=2;
  WriteComm;

  Timer2.Enabled:=true;

end;

